---
import { SEO } from 'astro-seo';
import { getLangFromUrl, useTranslations, languages, translatePath, defaultLang } from '../i18n/utils';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.tsx';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schemas?: unknown[];
  noindex?: boolean;
}

const { title, description, image, schemas, noindex } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const siteUrl = Astro.site?.toString() || 'https://igawo.pl';
const pageTitle = title ? `${title} | igawo.pl` : 'igawo.pl';
const pageDescription = description || t('common.description');
const ogImage = image ? new URL(image, siteUrl).toString() : new URL(`/images/og-${lang}.jpg`, siteUrl).toString();
const ogImageAlt = title ? `${title} — igawo.pl` : 'igawo.pl';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

const cookieMessages = {
  title: t('cookie.title'),
  description: t('cookie.description'),
  acceptAll: t('cookie.acceptAll'),
  acceptNecessary: t('cookie.acceptNecessary'),
  settings: t('cookie.settings'),
  save: t('cookie.save'),
  necessary: t('cookie.necessary'),
  necessaryDesc: t('cookie.necessaryDesc'),
  analytics: t('cookie.analytics'),
  analyticsDesc: t('cookie.analyticsDesc'),
  marketing: t('cookie.marketing'),
  marketingDesc: t('cookie.marketingDesc'),
};

// Hreflang alternates
const alternateLangs = Object.keys(languages) as Array<keyof typeof languages>;
const alternates = alternateLangs.map((code) => {
  const translatedPath = translatePath(Astro.url.pathname, lang, code);
  const href = new URL(translatedPath, siteUrl).toString();
  const hreflang = code === 'pl' ? 'pl-PL' : code === 'en' ? 'en-US' : 'de-DE';
  return { hreflang, href };
});

const xDefaultPath = translatePath(Astro.url.pathname, lang, defaultLang);
const xDefaultHref = new URL(xDefaultPath, siteUrl).toString();
---

<!doctype html>
<html lang={lang} class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <!-- Resource hints -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/geist@1.2.2/dist/fonts/geist-sans/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <SEO
      title={pageTitle}
      description={pageDescription}
      openGraph={{
        basic: {
          title: pageTitle,
          type: 'website',
          image: ogImage,
          url: canonicalUrl,
        },
        optional: {
          description: pageDescription,
          locale: lang === 'pl' ? 'pl_PL' : lang === 'en' ? 'en_US' : 'de_DE',
          localeAlternate: alternateLangs
            .filter((l) => l !== lang)
            .map((l) => (l === 'pl' ? 'pl_PL' : l === 'en' ? 'en_US' : 'de_DE')),
          siteName: 'igawo.pl',
        },
        image: {
          alt: ogImageAlt,
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: pageTitle,
        description: pageDescription,
        image: ogImage,
        imageAlt: ogImageAlt,
      }}
    />
    {schemas && schemas.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(schemas)} />
    )}
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="bg-stone-25 text-stone-900 font-sans">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-stone-900 focus:rounded-lg focus:shadow-lg">
      {t('common.skipToContent')}
    </a>
    <Header />
    <main id="main-content" class="overflow-x-hidden w-full max-w-full">
      <slot />
    </main>
    <Footer />
    <CookieBanner client:load lang={lang} messages={cookieMessages} />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {});
        });
      }
    </script>
  </body>
</html>
