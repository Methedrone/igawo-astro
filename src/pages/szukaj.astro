---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
import { breadcrumbSchema } from '../lib/schema';

const lang = 'pl';
const t = useTranslations(lang);

const schemas = [
  breadcrumbSchema([
    { name: t('nav.home'), item: '/pl' },
    { name: t('nav.search') },
  ], lang),
];
---

<Layout
  title="Wyszukiwarka"
  description="Przeszukaj całą zawartość strony igawo.pl"
  schemas={schemas}
>
  <section class="min-h-[60vh] flex flex-col items-center justify-center px-4 pt-32 pb-20">
    <div class="max-w-xl w-full text-center">
      <h1 class="text-3xl font-bold tracking-tight text-stone-900 mb-4">
        {t('nav.search')}
      </h1>
      <p class="text-stone-500 mb-8">
        Użyj skrótu klawiszowego <kbd class="px-2 py-1 bg-stone-100 rounded text-sm font-mono">Ctrl+K</kbd> z dowolnego miejsca na stronie, aby otworzyć wyszukiwarkę.
      </p>
      <div class="glass-panel rounded-2xl p-8 border border-white/40">
        <div class="flex items-center gap-3 px-4 py-3 bg-stone-50 rounded-xl border border-stone-200">
          <svg
            class="w-5 h-5 text-stone-400"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.3-4.3" />
          </svg>
          <span class="text-stone-400 text-sm">{t('search.placeholder')}</span>
          <span class="ml-auto text-xs text-stone-300 font-mono">Ctrl+K</span>
        </div>
        <p class="mt-4 text-sm text-stone-400">
          Wyszukiwarka przeszukuje wszystkie strony, usługi, pliki do pobrania, formularze i artykuły bloga.
        </p>
      </div>
    </div>
  </section>
</Layout>
