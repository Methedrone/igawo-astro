---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { languages, useTranslations, getLocalizedPath } from '../../i18n/utils';
import { getCollection } from 'astro:content';
import { breadcrumbSchema, faqPageSchema } from '../../lib/schema';
import ScrollReveal from '../../components/animations/ScrollReveal';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

const allFaq = await getCollection('faq');
const faq = allFaq
  .filter((item) => item.data.lang === lang)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const pageTitle = t('faq.pageTitle');

const homePath = getLocalizedPath('/', lang);
const schemas = [
  breadcrumbSchema([
    { name: t('nav.home'), item: homePath },
    { name: t('nav.faq') },
  ], lang),
  faqPageSchema(
    faq.map((item) => ({
      question: item.data.question,
      answer: item.body?.trim() || '',
    })),
    lang
  ),
];
---

<Layout title={t('nav.faq')} description={t('meta.faq.description')} schemas={schemas}>

  <div class="min-h-[100dvh] px-6 py-32 max-w-4xl mx-auto">
    <ScrollReveal client:load>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-stone-950">{pageTitle}</h1>
        <p class="mt-6 text-lg text-stone-500 leading-relaxed">{t('meta.faq.description')}</p>
      </div>
    </ScrollReveal>

    <div class="space-y-4">
      {faq.map((item, index) => (
        <ScrollReveal client:visible delay={index * 0.05}>
          <details class="group rounded-2xl bg-stone-50 border border-stone-200/40 open:bg-white open:shadow-[0_4px_20px_-10px_rgba(0,0,0,0.08)] transition-all duration-300">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none select-none">
              <span class="text-base md:text-lg font-semibold text-stone-900 group-open:text-brand-800 transition-colors">
                {item.data.question}
              </span>
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-white border border-stone-200/60 flex items-center justify-center text-stone-400 group-open:text-brand-600 group-open:rotate-180 transition-all duration-300">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-stone-600 leading-relaxed">
              <p>{item.body?.trim()}</p>
            </div>
          </details>
        </ScrollReveal>
      ))}
    </div>

    <ScrollReveal client:visible delay={0.3}>
      <div class="mt-20 rounded-[2rem] bg-brand-50 border border-brand-200/40 p-8 md:p-12 text-center">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-stone-900">
          {t('faq.ctaTitle')}
        </h2>
        <p class="mt-4 text-stone-500 max-w-xl mx-auto">
          {t('faq.ctaText')}
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="tel:+48570016826"
            class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-stone-900 bg-white border border-stone-200 rounded-full hover:bg-stone-50 transition-colors"
          >
            <svg class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            +48 570 016 826
          </a>
          <a
            href={getLocalizedPath('/kontakt', lang)}
            class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-stone-900 rounded-full hover:bg-stone-800 transition-colors"
          >
            <svg class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            {t('faq.ctaButton')}
          </a>
        </div>
      </div>
    </ScrollReveal>
  </div>
</Layout>
