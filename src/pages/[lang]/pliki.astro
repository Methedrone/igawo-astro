---
export const prerender = true;
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { languages, useTranslations, getLocalizedPath } from '../../i18n/utils';
import { breadcrumbSchema } from '../../lib/schema';
import DownloadsSection from '../../components/sections/DownloadsSection.astro';
import CtaSection from '../../components/sections/CtaSection.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

const pageIdMap: Record<string, string> = {
  pl: 'pliki',
  en: 'downloads',
  de: 'dateien',
};
const pageEntry = await getEntry('pages', pageIdMap[lang] ?? 'pliki');
const pageDesc = pageEntry?.data.description ?? t('meta.downloads.description');

const homePath = getLocalizedPath('/', lang);
const schemas = [
  breadcrumbSchema([
    { name: t('nav.home'), item: homePath },
    { name: t('nav.downloads') },
  ], lang),
];
---

<Layout title={t('nav.downloads')} description={pageDesc} schemas={schemas}>
  <div class="pt-32 md:pt-40 pb-16 section-padding">
    <div class="container-wide">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-stone-950 leading-none">{t('nav.downloads')}</h1>
    </div>
  </div>
  <DownloadsSection lang={lang} />
  <CtaSection lang={lang} />
</Layout>
