---
import { useTranslations } from '../../i18n/utils';
import ScrollReveal from '../animations/ScrollReveal';
import ContactForm from '../forms/ContactForm';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'pl' | 'en' | 'de');
---

<section class="py-32 md:py-48 section-padding" aria-labelledby="contact-heading">
  <div class="container-wide">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <div>
        <ScrollReveal client:visible>
          <h2 id="contact-heading" class="text-4xl md:text-5xl font-bold tracking-tighter text-stone-950 leading-none">
            {t('contact.title')} <span class="text-gradient">{t('contact.titleHighlight')}</span>
          </h2>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.15}>
          <p class="mt-8 text-lg text-stone-600 leading-relaxed max-w-[55ch]">
            {t('contact.paragraph')}
          </p>
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.25}>
          <div class="mt-12 space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-stone-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-stone-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-stone-400 uppercase tracking-wide">{t('contact.email.label')}</div>
                <a href={`mailto:${t('contact.email.value')}`} class="text-lg font-semibold text-stone-900 hover:text-brand-700 transition-colors">{t('contact.email.value')}</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-stone-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-stone-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-stone-400 uppercase tracking-wide">{t('contact.phone.label')}</div>
                <a href={`tel:${t('contact.phone.value').replace(/\s/g, '')}`} class="text-lg font-semibold text-stone-900 hover:text-brand-700 transition-colors">{t('contact.phone.value')}</a>
                <div class="text-sm text-stone-500 mt-1">{t('contact.phone2.value')}</div>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-stone-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-stone-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-stone-400 uppercase tracking-wide">{t('contact.address.label')}</div>
                <address class="text-lg font-semibold text-stone-900 not-italic">{t('contact.address.value')}</address>
              </div>
            </div>
          </div>
        </ScrollReveal>
      </div>

      <ScrollReveal client:visible delay={0.2}>
        <div class="glass-panel rounded-[2.5rem] p-8 md:p-12">
          <ContactForm client:load lang={lang as 'pl' | 'en' | 'de'} />
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
