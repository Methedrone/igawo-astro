---
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';
import ScrollReveal from '../animations/ScrollReveal';
import StaggerReveal from '../animations/StaggerReveal';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'pl' | 'en' | 'de');

const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials
  .filter((s) => s.data.lang === lang)
  .slice(0, 3);
---

<section class="py-32 md:py-48 section-padding bg-stone-50" aria-labelledby="testimonials-heading">
  <div class="container-wide">
    <ScrollReveal client:visible>
      <div class="max-w-3xl mb-20">
        <h2 id="testimonials-heading" class="text-4xl md:text-5xl font-bold tracking-tighter text-stone-950 leading-none">
          {t('testimonials.title')} <span class="text-gradient">{t('testimonials.titleHighlight')}</span>
        </h2>
        <p class="mt-6 text-lg text-stone-500 leading-relaxed max-w-[65ch]">
          {t('testimonials.subtitle')}
        </p>
      </div>
    </ScrollReveal>

    <StaggerReveal client:visible className="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((item) => (
        <div class="group relative glass-panel rounded-[2rem] p-8 md:p-10 transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.08)] hover:border-stone-300/60 flex flex-col">
          <div class="flex items-center gap-1 mb-6">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-brand-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>

          <div class="flex-1 text-stone-600 leading-relaxed text-base">
            {item.body}
          </div>

          <div class="mt-8 pt-6 border-t border-stone-200/60">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-brand-100 flex items-center justify-center text-brand-700 font-bold text-sm">
                {item.data.author.split(' ').map((n: string) => n[0]).join('')}
              </div>
              <div>
                <div class="font-semibold text-stone-900">{item.data.author}</div>
                <div class="text-sm text-stone-500">{item.data.role}</div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </StaggerReveal>
  </div>
</section>
