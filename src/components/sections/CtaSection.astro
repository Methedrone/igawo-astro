---
import { getLocalizedPath, useTranslations } from '../../i18n/utils';
import ScrollReveal from '../animations/ScrollReveal';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'pl' | 'en' | 'de');
---

<section class="py-32 md:py-48 section-padding relative overflow-hidden" aria-labelledby="cta-heading">
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-stone-900" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-[url('/images/hero-2.avif')] bg-cover bg-center opacity-10" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-stone-950 via-stone-900/80 to-stone-900" aria-hidden="true"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-500/10 rounded-full blur-[120px]" aria-hidden="true"></div>
  </div>

  <div class="container-wide text-center">
    <ScrollReveal client:visible>
      <h2 id="cta-heading" class="text-4xl md:text-6xl font-bold tracking-tighter text-white leading-[1.05] max-w-4xl mx-auto">
        {t('cta.title')} <span class="text-brand-400">{t('cta.titleHighlight')}</span>
      </h2>
    </ScrollReveal>

    <ScrollReveal client:visible delay={0.2}>
      <p class="mt-8 text-lg md:text-xl text-stone-400 max-w-2xl mx-auto leading-relaxed">
        {t('cta.subtitle')}
      </p>
    </ScrollReveal>

    <ScrollReveal client:visible delay={0.35}>
      <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
        href={getLocalizedPath('/kontakt', lang)}
        class="group inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-stone-900 bg-white rounded-full hover:bg-stone-100 transition-all active:scale-[0.98] shadow-[0_8px_24px_-6px_rgba(0,0,0,0.25)]"
          data-track="cta_click"
        data-track-label="cta_primary_contact"
          >
            {t('cta.primary')}
          <svg class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a
        href={getLocalizedPath('/oferta', lang)}
        class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white border border-white/20 rounded-full hover:bg-white/10 transition-all active:scale-[0.98]"
          data-track="cta_click"
        data-track-label="cta_secondary_offer"
          >
            {t('cta.secondary')}
        </a>
      </div>
    </ScrollReveal>
  </div>
</section>
