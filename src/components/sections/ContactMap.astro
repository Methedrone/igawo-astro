---
import { useTranslations } from '../../i18n/utils';
import ScrollReveal from '../animations/ScrollReveal';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'pl' | 'en' | 'de');

const mapQuery = encodeURIComponent(t('contact.address.value'));
const mapSrc = `https://maps.google.com/maps?q=${mapQuery}&t=&z=15&ie=UTF8&iwloc=&output=embed`;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${mapQuery}`;
---

<section class="pb-16 md:pb-24 section-padding" aria-labelledby="map-heading">
  <div class="container-wide">
    <ScrollReveal client:visible>
      <h2 id="map-heading" class="text-3xl md:text-4xl font-bold tracking-tighter text-stone-950 leading-none mb-8">
        {t('contact.map.title')}
      </h2>
    </ScrollReveal>
    <ScrollReveal client:visible delay={0.15}>
      <div class="rounded-[2.5rem] overflow-hidden border border-stone-200 shadow-sm aspect-video bg-stone-100">
        <iframe
          src={mapSrc}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={t('contact.map.title')}
          class="w-full h-full"
        ></iframe>
      </div>
    </ScrollReveal>
    <ScrollReveal client:visible delay={0.25}>
      <div class="mt-6 text-center">
        <a
          href={directionsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-base font-semibold text-brand-700 hover:text-brand-500 transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/>
          </svg>
          {t('contact.map.directions')}
        </a>
      </div>
    </ScrollReveal>
  </div>
</section>
