---
import { useTranslations } from '../../i18n/utils';
import ScrollReveal from '../animations/ScrollReveal';
import ImageScaleOnScroll from '../animations/ImageScaleOnScroll';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'pl' | 'en' | 'de');
---

<section class="py-32 md:py-48 section-padding bg-stone-50" aria-labelledby="about-heading">
  <div class="container-wide">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div>
        <ScrollReveal client:visible>
          <h2 id="about-heading" class="text-4xl md:text-5xl font-bold tracking-tighter text-stone-950 leading-none">
            {t('about.title')} <span class="text-gradient">{t('about.titleHighlight')}</span>
          </h2>
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.15}>
          <p class="mt-8 text-lg text-stone-600 leading-relaxed">
            {t('about.p1')}
          </p>
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.25}>
          <p class="mt-6 text-lg text-stone-600 leading-relaxed">
            {t('about.p2')}
          </p>
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.35}>
          <div class="mt-12 grid grid-cols-2 gap-8">
            <div>
              <div class="text-4xl font-bold tracking-tight text-stone-900">{t('about.stat1.value')}</div>
              <div class="mt-1 text-sm text-stone-500 font-medium">{t('about.stat1.label')}</div>
            </div>
            <div>
              <div class="text-4xl font-bold tracking-tight text-stone-900">{t('about.stat2.value')}</div>
              <div class="mt-1 text-sm text-stone-500 font-medium">{t('about.stat2.label')}</div>
            </div>
            <div>
              <div class="text-4xl font-bold tracking-tight text-stone-900">{t('about.stat3.value')}</div>
              <div class="mt-1 text-sm text-stone-500 font-medium">{t('about.stat3.label')}</div>
            </div>
            <div>
              <div class="text-4xl font-bold tracking-tight text-stone-900">{t('about.stat4.value')}</div>
              <div class="mt-1 text-sm text-stone-500 font-medium">{t('about.stat4.label')}</div>
            </div>
          </div>
        </ScrollReveal>
      </div>

      <ScrollReveal client:visible delay={0.2} className="relative">
        <div class="relative aspect-[4/5] rounded-[2.5rem] overflow-hidden">
          <ImageScaleOnScroll
            client:visible
            src="/images/about-office.jpg"
            alt={t('about.badge.title')}
            className="absolute inset-0"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-stone-950/20 to-transparent" aria-hidden="true"></div>
        </div>
        <div class="absolute -bottom-6 -left-6 glass-pill rounded-2xl p-5 shadow-xl" aria-hidden="true">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <div>
              <div class="text-sm font-semibold text-stone-900">{t('about.badge.title')}</div>
              <div class="text-xs text-stone-500">{t('about.badge.subtitle')}</div>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
