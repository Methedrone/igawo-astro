---
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';
import ScrollReveal from '../animations/ScrollReveal';
import StaggerReveal from '../animations/StaggerReveal';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'pl' | 'en' | 'de');

const allPartners = await getCollection('partners');
const partners = allPartners
  .filter((s) => s.data.lang === lang);
---

<section class="py-32 md:py-48 section-padding" aria-labelledby="partners-heading">
  <div class="container-wide">
    <ScrollReveal client:visible>
      <div class="max-w-3xl mb-20">
        <h2 id="partners-heading" class="text-4xl md:text-5xl font-bold tracking-tighter text-stone-950 leading-none">
          {t('partners.title')} <span class="text-gradient">{t('partners.titleHighlight')}</span>
        </h2>
        <p class="mt-6 text-lg text-stone-500 leading-relaxed max-w-[65ch]">
          {t('partners.subtitle')}
        </p>
      </div>
    </ScrollReveal>

    <StaggerReveal client:visible className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {partners.map((item) => (
        <div class="group relative overflow-hidden rounded-[2rem] bg-linear-to-br from-stone-50 to-white border border-stone-200/40 p-8 md:p-10 transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.08)] hover:border-stone-300/60 flex flex-col justify-between min-h-[240px]">
          <div>
            <div class="w-14 h-14 rounded-2xl bg-brand-50 border border-brand-100/50 flex items-center justify-center text-brand-700 mb-6">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold tracking-tight text-stone-900 group-hover:text-brand-800 transition-colors duration-300">
              {item.data.title.name}
            </h3>
            <p class="mt-2 text-sm text-stone-500 leading-relaxed">
              {item.data.description}
            </p>
          </div>

          <div class="absolute -bottom-10 -right-10 w-40 h-40 rounded-full bg-brand-200/20 blur-3xl group-hover:bg-brand-200/40 transition-all duration-700" aria-hidden="true" />
        </div>
      ))}
    </StaggerReveal>
  </div>
</section>
