---
import { getCollection } from 'astro:content';
import { getLocalizedPath, useTranslations } from '../../i18n/utils';
import ScrollReveal from '../animations/ScrollReveal';
import StaggerReveal from '../animations/StaggerReveal';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'pl' | 'en' | 'de');

const allServices = await getCollection('services');
const services = allServices
  .filter((s) => s.data.lang === lang)
  .slice(0, 5);

const gradients = [
  'from-brand-50 to-stone-50',
  'from-stone-100 to-stone-50',
  'from-brand-100/40 to-stone-50',
  'from-stone-200/30 to-stone-50',
  'from-brand-50 to-brand-100/30',
];

const icons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
];
---

<section class="py-32 md:py-48 section-padding" aria-labelledby="services-heading">
  <div class="container-wide">
    <ScrollReveal client:load>
      <div class="max-w-3xl mb-20">
        <h2 id="services-heading" class="text-4xl md:text-5xl font-bold tracking-tighter text-stone-950 leading-none">
          {t('services.sectionTitle')} <span class="text-gradient">{t('services.sectionTitleHighlight')}</span>
        </h2>
        <p class="mt-6 text-lg text-stone-500 leading-relaxed max-w-[65ch]">
          {t('services.sectionSubtitle')}
        </p>
      </div>
    </ScrollReveal>

    <StaggerReveal client:visible className="grid grid-cols-1 md:grid-cols-3 gap-4 auto-rows-[minmax(200px,auto)] grid-flow-dense">
      {services.map((service, i) => {
        const isLarge = i === 0;
        const isWide = i === 2;
        const gradient = gradients[i % gradients.length];
        const icon = icons[i % icons.length];

        return (
          <a
            href={getLocalizedPath('/oferta', lang)}
            class={`group relative overflow-hidden rounded-[2rem] bg-linear-to-br ${gradient} border border-stone-200/40 p-8 md:p-10 transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.08)] hover:border-stone-300/60 flex flex-col justify-between ${
              isLarge ? 'md:col-span-2 md:row-span-2' : ''
            } ${isWide ? 'md:col-span-2' : ''}`}
          >
            <div class="flex items-start justify-between">
              <div class="w-14 h-14 rounded-2xl bg-white/80 border border-stone-200/50 flex items-center justify-center text-stone-700 shadow-sm group-hover:scale-105 group-hover:shadow-md transition-all duration-500">
                <Fragment set:html={icon} />
              </div>
              <svg class="w-5 h-5 text-stone-300 group-hover:text-stone-500 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M7 17L17 7M17 7H7M17 7V17"/>
              </svg>
            </div>

            <div class="mt-8">
              <h3 class="text-xl md:text-2xl font-semibold tracking-tight text-stone-900 group-hover:text-brand-800 transition-colors duration-300">
                {service.data.title.name}
              </h3>
              {service.data.description && (
                <p class="mt-3 text-stone-500 leading-relaxed text-sm md:text-base line-clamp-3">
                  {service.data.description}
                </p>
              )}
            </div>

            <div class="absolute -bottom-10 -right-10 w-40 h-40 rounded-full bg-brand-200/20 blur-3xl group-hover:bg-brand-200/40 transition-all duration-700" aria-hidden="true" />
          </a>
        );
      })}
    </StaggerReveal>

    <ScrollReveal client:visible delay={0.3}>
      <div class="mt-16 text-center">
        <a
          href={getLocalizedPath('/oferta', lang)}
          class="inline-flex items-center gap-2 text-sm font-semibold text-stone-700 hover:text-brand-700 transition-colors group"
        >
          {t('services.viewAll')}
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </ScrollReveal>
  </div>
</section>
