---
import { useTranslations } from '../i18n/utils';
import ScrollReveal from './animations/ScrollReveal';

interface Props {
  lang: string;
  variant?: 'section' | 'footer';
}

const { lang, variant = 'section' } = Astro.props;
const t = useTranslations(lang as 'pl' | 'en' | 'de');

const isFooter = variant === 'footer';
---

{isFooter ? (
  <div class="lg:col-span-2" data-newsletter="footer">
    <h3 class="text-sm font-semibold text-stone-900 uppercase tracking-wide">{t('newsletter.label')}</h3>
    <p class="mt-4 text-sm text-stone-500 max-w-sm leading-relaxed">
      {t('newsletter.subtitle')}
    </p>
    <form
      class="mt-4 flex flex-col sm:flex-row gap-3"
      data-newsletter-form
      data-lang={lang}
      onsubmit="event.preventDefault();"
    >
      <div class="flex-1 relative">
        <label for="newsletter-email-footer" class="sr-only">{t('newsletter.placeholder')}</label>
        <input
          type="email"
          id="newsletter-email-footer"
          name="email"
          required
          class="w-full px-4 py-2.5 bg-stone-50 border border-stone-200 rounded-xl text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all text-sm"
          placeholder={t('newsletter.placeholder')}
        />
        <p data-newsletter-message class="absolute left-0 -bottom-6 text-xs hidden"></p>
      </div>
      <button
        type="submit"
        class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-stone-900 rounded-xl hover:bg-stone-800 transition-all active:scale-[0.98] whitespace-nowrap"
      >
        <span data-newsletter-button-text>{t('newsletter.button')}</span>
        <svg data-newsletter-spinner class="hidden ml-2 w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </button>
    </form>
    <p class="mt-8 text-xs text-stone-400">
      {t('newsletter.privacy')}
    </p>
  </div>
) : (
  <section class="py-24 md:py-32 section-padding bg-stone-50" aria-labelledby="newsletter-heading" data-newsletter="section">
    <div class="container-wide">
      <div class="max-w-2xl mx-auto text-center">
        <ScrollReveal client:visible>
          <h2 id="newsletter-heading" class="text-3xl md:text-4xl font-bold tracking-tighter text-stone-950 leading-tight">
            {t('newsletter.title')}
          </h2>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.1}>
          <p class="mt-4 text-lg text-stone-600 leading-relaxed">
            {t('newsletter.subtitle')}
          </p>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.2}>
          <form
            class="mt-8 flex flex-col sm:flex-row gap-4 max-w-lg mx-auto"
            data-newsletter-form
            data-lang={lang}
            onsubmit="event.preventDefault();"
          >
            <div class="flex-1 relative">
              <label for="newsletter-email-section" class="sr-only">{t('newsletter.placeholder')}</label>
              <input
                type="email"
                id="newsletter-email-section"
                name="email"
                required
                class="w-full px-5 py-3.5 bg-white border border-stone-200 rounded-2xl text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all"
                placeholder={t('newsletter.placeholder')}
              />
              <p data-newsletter-message class="absolute left-0 -bottom-6 text-sm hidden"></p>
            </div>
            <button
              type="submit"
              class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-stone-900 rounded-2xl hover:bg-stone-800 transition-all active:scale-[0.98] shadow-[0_8px_24px_-6px_rgba(0,0,0,0.25)] whitespace-nowrap"
            >
              <span data-newsletter-button-text>{t('newsletter.button')}</span>
              <svg data-newsletter-spinner class="hidden ml-2 w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
          </form>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.3}>
          <p class="mt-10 text-sm text-stone-500">
            {t('newsletter.privacy')}
          </p>
        </ScrollReveal>
      </div>
    </div>
  </section>
)}

<script>
  (function () {
    const forms = document.querySelectorAll<HTMLFormElement>('[data-newsletter-form]');

    forms.forEach((form) => {
      const messageEl = form.querySelector<HTMLParagraphElement>('[data-newsletter-message]');
      const buttonText = form.querySelector<HTMLSpanElement>('[data-newsletter-button-text]');
      const spinner = form.querySelector<SVGElement>('[data-newsletter-spinner]');
      const lang = form.dataset.lang || 'pl';

      const messages: Record<string, Record<string, string>> = {
        pl: {
          success: 'Dziękujemy za zapisanie się do newslettera!',
          error: 'Wystąpił błąd. Sprawdź adres e-mail i spróbuj ponownie.',
        },
        en: {
          success: 'Thank you for subscribing to our newsletter!',
          error: 'An error occurred. Please check your email address and try again.',
        },
        de: {
          success: 'Vielen Dank für Ihre Newsletter-Anmeldung!',
          error: 'Ein Fehler ist aufgetreten. Bitte überprüfen Sie Ihre E-Mail-Adresse und versuchen Sie es erneut.',
        },
      };

      function setLoading(loading: boolean) {
        if (buttonText) buttonText.textContent = loading
          ? (lang === 'pl' ? 'Wysyłanie...' : lang === 'de' ? 'Wird gesendet...' : 'Sending...')
          : '';
        if (spinner) spinner.classList.toggle('hidden', !loading);
        const btn = form.querySelector('button');
        if (btn) btn.disabled = loading;
      }

      function showMessage(type: 'success' | 'error', text: string) {
        if (!messageEl) return;
        messageEl.textContent = text;
        messageEl.classList.remove('hidden', 'text-brand-600', 'text-red-600');
        messageEl.classList.add(type === 'success' ? 'text-brand-600' : 'text-red-600');
      }

      function hideMessage() {
        if (!messageEl) return;
        messageEl.classList.add('hidden');
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        hideMessage();

        const data = new FormData(form);
        const email = String(data.get('email') || '').trim();

        if (!email) {
          showMessage('error', messages[lang]?.error || messages.en.error);
          return;
        }

        setLoading(true);

        try {
          const res = await fetch('/api/newsletter', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });

          const result = await res.json().catch(() => ({}));

          if (res.ok && result.success) {
            showMessage('success', messages[lang]?.success || messages.en.success);
            form.reset();
          } else {
            showMessage('error', messages[lang]?.error || messages.en.error);
          }
        } catch {
          showMessage('error', messages[lang]?.error || messages.en.error);
        } finally {
          setLoading(false);
        }
      });
    });
  })();
</script>