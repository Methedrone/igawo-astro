---
import { getLangFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';
import NewsletterSignup from './NewsletterSignup.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: lang === 'pl' ? 'Usługi' : lang === 'de' ? 'Dienstleistungen' : 'Services',
    links: [
      { label: lang === 'pl' ? 'Rozliczenie Niemcy' : lang === 'de' ? 'Steuererklärung Deutschland' : 'German Tax Return', href: getLocalizedPath('/oferta', lang) },
      { label: lang === 'pl' ? 'Rozliczenie Holandia' : lang === 'de' ? 'Steuererklärung Niederlande' : 'Dutch Tax Return', href: getLocalizedPath('/oferta', lang) },
      { label: 'Kindergeld', href: getLocalizedPath('/oferta', lang) },
      { label: lang === 'pl' ? 'Upadłość konsumencka' : lang === 'de' ? 'Verbraucherinsolvenz' : 'Consumer Bankruptcy', href: getLocalizedPath('/oferta', lang) },
    ],
  },
  {
    title: lang === 'pl' ? 'Firma' : lang === 'de' ? 'Unternehmen' : 'Company',
    links: [
      { label: t('nav.about'), href: getLocalizedPath('/o-nas', lang) },
      { label: t('nav.pricing'), href: getLocalizedPath('/cennik', lang) },
      { label: t('nav.contact'), href: getLocalizedPath('/kontakt', lang) },
      { label: t('nav.downloads'), href: getLocalizedPath('/pliki', lang) },
      { label: t('nav.forms'), href: getLocalizedPath('/kwestionariusze', lang) },
    ],
  },
];
---

<footer class="border-t border-stone-200/50 bg-white">
  <div class="container-wide section-padding py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <div class="lg:col-span-2">
        <a href={getLocalizedPath('/', lang)} class="text-xl font-bold tracking-tight text-stone-900 hover:text-brand-700 transition-colors">
          igawo.pl
        </a>
        <p class="mt-4 text-stone-500 max-w-sm leading-relaxed">
          {lang === 'pl'
            ? 'Profesjonalne rozliczenia podatkowe dla Polaków pracujących za granicą. Niemcy, Holandia — odzyskaj to, co Twoje.'
            : lang === 'de'
              ? 'Professionelle Steuererklärungen für Polen im Ausland. Deutschland, Niederlande — holen Sie sich zurück, was Ihnen zusteht.'
              : 'Professional tax returns for Poles working abroad. Germany, Netherlands — recover what is yours.'}
        </p>
        <div class="mt-6 flex items-center gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-stone-100 flex items-center justify-center text-stone-500 hover:bg-stone-900 hover:text-white transition-all" aria-label="Facebook (wkrótce)" aria-disabled="true" tabindex="-1">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-stone-100 flex items-center justify-center text-stone-500 hover:bg-stone-900 hover:text-white transition-all" aria-label="LinkedIn (wkrótce)" aria-disabled="true" tabindex="-1">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-stone-100 flex items-center justify-center text-stone-500 hover:bg-stone-900 hover:text-white transition-all" aria-label="WhatsApp (wkrótce)" aria-disabled="true" tabindex="-1">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      {footerLinks.map((group) => (
        <div>
          <h3 class="text-sm font-semibold text-stone-900 uppercase tracking-wide">{group.title}</h3>
          <ul class="mt-4 space-y-3">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="text-stone-500 hover:text-stone-900 transition-colors text-sm">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 pt-12 border-t border-stone-200/50">
      <NewsletterSignup lang={lang} variant="footer" />
    </div>

    <div class="mt-16 pt-8 border-t border-stone-200/50 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-stone-400">
        &copy; {currentYear} igawo.pl. {lang === 'pl' ? 'Wszelkie prawa zastrzeżone.' : lang === 'de' ? 'Alle Rechte vorbehalten.' : 'All rights reserved.'}
      </p>
      <div class="flex items-center gap-6">
        <a href={getLocalizedPath('/polityka-prywatnosci', lang)} class="text-sm text-stone-400 hover:text-stone-600 transition-colors">{t('nav.privacy')}</a>
        <a href={getLocalizedPath('/regulamin', lang)} class="text-sm text-stone-400 hover:text-stone-600 transition-colors">{t('nav.terms')}</a>
      </div>
    </div>
  </div>
</footer>
